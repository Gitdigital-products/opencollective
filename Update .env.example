---

#### .env.example

```bash
# GitDigital OpenCollective Environment Configuration
# Copy this file to .env and update values

# Server Configuration
PORT=3000
HOST=localhost
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/gitdigital
DATABASE_SSL=false

# Open Collective API
OPENCOLLECTIVE_API_KEY=your_api_key_here
OPENCOLLECTIVE_COLLECTIVE_SLUG=gitdigital
OPENCOLLECTIVE_API_URL=https://api.opencollective.com

# GitHub Integration
GITHUB_TOKEN=your_github_token
GITHUB_REPO=Gitdigital-products/opencollective
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# Authentication
SESSION_SECRET=your_session_secret_here
JWT_SECRET=your_jwt_secret_here

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@gitdigital.io

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Feature Flags
ENABLE_DASHBOARD=true
ENABLE_API=true
ENABLE_NOTIFICATIONS=true
ENABLE_EXPERIMENTAL_FEATURES=false

# Rate Limiting
RATE_LIMIT_WINDOW=900000  # 15 minutes in ms
RATE_LIMIT_MAX=100

# Cache
REDIS_URL=redis://localhost:6379
CACHE_TTL=3600

# External Services
SENTRY_DSN=your_sentry_dsn
NEW_RELIC_LICENSE_KEY=your_new_relic_key
SEGMENT_WRITE_KEY=your_segment_key

# Security
CORS_ORIGIN=http://localhost:3000
CSP_ENABLED=true
HELMET_ENABLED=true
ENCRYPTION_KEY=your_encryption_key

# Payment Processing
STRIPE_PUBLIC_KEY=pk_test_your_key
STRIPE_SECRET_KEY=sk_test_your_key
CRYPTO_WALLET_ADDRESS=0xYourWalletAddress

# Multi-sig Wallet
MULTISIG_REQUIRED_SIGNATURES=3
MULTISIG_WALLET_ADDRESS=0xMultisigAddress

# Monitoring
HEALTH_CHECK_PATH=/health
METRICS_ENABLED=true
METRICS_PORT=9090

# Development
DEBUG=gitdigital:*
SEED_DATA=true
SKIP_AUTH=false

# Production
PRODUCTION_DOMAIN=gitdigital.io
PRODUCTION_SSL_CERT=/path/to/cert.pem
PRODUCTION_SSL_KEY=/path/to/key.pem
